<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Canlı Mac Skorları - Futbol, Basketbol, Tenis - SportScore kaynaklı gerçek zamanlı sonuçlar" />
    <title>@ViewData["Title"] - SKORBORD</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/skorbord.css" />
</head>
<body>
    <div class="app-shell">

        <nav class="top-nav">
            <div class="nav-inner">
                <a href="/" class="nav-logo">
                    <div class="logo-icon">⚽</div>
                    SKORBORD
                </a>
                <div class="nav-links">
                    <a href="/" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fas fa-home mr-1"></i>Canlı Skorlar
                    </a>
                    <a href="/Home/About" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "active" : "")">
                        <i class="fas fa-info-circle mr-1"></i>Hakkında
                    </a>
                </div>
            </div>
            <div class="refresh-bar">
                <div class="refresh-bar-fill" id="refreshProgress"></div>
            </div>
        </nav>

        <main class="main-content">
            @if (TempData["Error"] != null)
            {
                <div class="error-card mb-4" style="margin-bottom:16px">
                    <i class="fas fa-exclamation-triangle" style="margin-right:8px;color:#ef4444"></i>
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </main>

        <footer class="app-footer">
            <p>
                SKORBORD &middot; Veriler <a href="https://rapidapi.com/sportscore-sportscore-default/api/sportscore1" target="_blank">SportScore API</a> kaynağından canlı çekilmektedir
            </p>
        </footer>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
