@using Skorbord.API.Models
@model LeagueViewModel
@{
    ViewData["Title"] = $"{ViewBag.LeagueName} - Maçlar";
    var leagueName = (string)(ViewBag.LeagueName ?? "");
    var selectedDate = (string)(ViewBag.SelectedDate ?? DateTime.Now.ToString("yyyy-MM-dd"));
    var summary = ViewBag.Summary as LivescoresSummary;
    var apiError = (bool)(ViewBag.ApiError ?? false);
}

<!-- Breadcrumb -->
<div class="mb-6">
    <nav class="flex items-center gap-2 text-sm text-slate-400">
        <a href="/" class="hover:text-emerald-400 transition">
            <i class="fas fa-home mr-1"></i>Ana Sayfa
        </a>
        <i class="fas fa-chevron-right text-xs text-slate-600"></i>
        <span class="text-slate-200">@leagueName</span>
    </nav>
</div>

@if (apiError || Model == null)
{
    <div class="error-card mb-6">
        <div class="flex items-center gap-4">
            <div class="text-4xl">🚫</div>
            <div>
                <h3 class="text-lg font-bold text-red-300">Veri Alınamadı</h3>
                <p class="text-red-400 text-sm mt-1">
                    @(apiError ? "API bağlantı hatası. Lütfen tekrar deneyin." : $"'{leagueName}' ligi bu tarih için bulunamadı.")
                </p>
                <a href="/" class="mt-3 inline-flex items-center btn-retry">
                    <i class="fas fa-arrow-left mr-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
}
else
{
    <!-- Lig Header -->
    <div class="league-detail-header mb-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="flex items-center gap-4">
                <div class="league-sport-icon @(Model.Sport == "Futbol" ? "soccer" : Model.Sport == "Basketbol" ? "basketball" : "tennis")">
                    @if (Model.Sport == "Futbol")
                    { <i class="fas fa-futbol"></i> }
                    else if (Model.Sport == "Basketbol")
                    { <i class="fas fa-basketball-ball"></i> }
                    else
                    { <i class="fas fa-table-tennis"></i> }
                </div>
                <div>
                    <h1 class="text-2xl md:text-3xl font-black text-white">@Model.League</h1>
                    <div class="flex items-center gap-3 mt-1">
                        <span class="text-slate-400 text-sm">
                            <i class="fas fa-globe-europe mr-1 text-emerald-400"></i>@Model.Country
                        </span>
                        <span class="text-slate-400 text-sm">
                            <i class="fas fa-futbol mr-1 text-blue-400"></i>@Model.Sport
                        </span>
                        <span class="league-match-count">@Model.Matches.Count maç</span>
                    </div>
                </div>
            </div>

            <div class="flex gap-3">
                <a href="@($"/?date={selectedDate}")" class="btn-secondary">
                    <i class="fas fa-arrow-left mr-2"></i>Geri
                </a>
                <button onclick="location.reload()" class="btn-primary">
                    <i class="fas fa-sync-alt mr-2"></i>Yenile
                </button>
            </div>
        </div>
    </div>

    <!-- Maç Listesi -->
    <div class="matches-container">
        @if (!Model.Matches.Any())
        {
            <div class="empty-state">
                <div class="text-5xl mb-3">📋</div>
                <p class="text-slate-400">Bu lig için maç bulunamadı.</p>
            </div>
        }
        else
        {
            @foreach (var match in Model.Matches.OrderBy(m => m.StartTime))
            {
                <a href="/Home/MatchDetail/@match.Id?date=@selectedDate" class="match-row group @(match.IsLive ? "live" : match.State == "post" ? "finished" : "")">
                    <!-- Saat & Durum -->
                    <div class="match-time-col">
                        <span class="match-time">@match.StartTime</span>
                        @if (match.IsLive)
                        {
                            <span class="status-live">
                                <span class="status-dot"></span>@match.Status
                            </span>
                        }
                        else if (match.State == "post")
                        {
                            <span class="status-finished">@match.Status</span>
                        }
                        else
                        {
                            <span class="status-scheduled">@match.Status</span>
                        }
                    </div>

                    <!-- Ev Sahibi -->
                    <div class="match-team home">
                        <span class="team-name">@match.HomeTeam</span>
                    </div>

                    <!-- Skor -->
                    <div class="match-score-col">
                        @if (match.HomeScore.HasValue && match.AwayScore.HasValue)
                        {
                            <div class="score-box @(match.IsLive ? "live" : "")">
                                <span class="score-num">@match.HomeScore</span>
                                <span class="score-sep">:</span>
                                <span class="score-num">@match.AwayScore</span>
                            </div>
                            @if (match.HalfTimeScore != null)
                            {
                                <div class="ht-score">İY: @match.HalfTimeScore.Home - @match.HalfTimeScore.Away</div>
                            }
                        }
                        else
                        {
                            <div class="score-box scheduled">
                                <span class="text-slate-400 text-sm font-bold">vs</span>
                            </div>
                        }
                    </div>

                    <!-- Deplasman -->
                    <div class="match-team away">
                        <span class="team-name">@match.AwayTeam</span>
                    </div>

                </a>
            }
        }
    </div>
}

@section Scripts {
<script>
    // Canlı maç varsa her 30 sn'de yenile
    @if (Model?.Matches.Any(m => m.IsLive) == true)
    {
        <text>
        setTimeout(() => location.reload(), 30000);
        </text>
    }
</script>
}
